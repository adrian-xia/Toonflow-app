# Phase 0 monorepo placeholder web image
FROM node:24-alpine AS builder

WORKDIR /workspace

RUN corepack enable && \
    npm config set registry https://registry.npmmirror.com/ && \
    pnpm config set registry https://registry.npmmirror.com/

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json tsconfig.json ./
COPY apps/web/package.json apps/web/package.json

RUN pnpm install --frozen-lockfile --filter @toonflow/web...
RUN pnpm --filter @toonflow/web build
RUN mkdir -p apps/web/dist && \
    printf '%s\n' '<!doctype html><html><head><meta charset="utf-8"><title>Toonflow Web Placeholder</title></head><body><h1>@toonflow/web placeholder</h1></body></html>' > apps/web/dist/index.html

FROM nginx:1.27-alpine

COPY --from=builder /workspace/apps/web/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
