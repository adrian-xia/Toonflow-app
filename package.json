{
  "name": "toonflow",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @toonflow/api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @toonflow/db db:migrate",
    "db:rollback": "pnpm --filter @toonflow/db db:rollback",
    "db:types": "pnpm --filter @toonflow/db db:types",
    "db:test:up": "pnpm --filter @toonflow/db db:test:up",
    "db:test:down": "pnpm --filter @toonflow/db db:test:down"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
